# ===== LLM 配置 =====
LLM_API_KEY=your-api-key-here
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=16384

# ===== Embedding 配置 =====
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== Redis 配置 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════
# Qdrant 配置 — 一键切换本地 / Docker 模式
# ═══════════════════════════════════════════════════════════════
#
# 【本地文件模式】（不需要 Docker，数据存 data/qdrant_local/）
#   QDRANT_HOST=
#   QDRANT_PORT=
#
# 【Docker 服务器模式】（需先 docker compose up -d qdrant）
#   QDRANT_HOST=127.0.0.1
#   QDRANT_PORT=6333
#
# 切换方式：注释/取消注释下面两行即可
# ═══════════════════════════════════════════════════════════════

# --- 本地文件模式（默认）---
QDRANT_HOST=
QDRANT_PORT=

# --- Docker 服务器模式（取消下面注释，注释上面两行）---
# QDRANT_HOST=127.0.0.1
# QDRANT_PORT=6333

QDRANT_API_KEY=

# ===== PostgreSQL 配置 =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agent_cs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ===== LangFuse 配置 =====
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ===== 应用配置 =====
APP_NAME=multi-agent-cs
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=INFO

# ===== 安全配置 =====
SECRET_KEY=your-secret-key-here
API_RATE_LIMIT=100
MAX_TOKENS_PER_SESSION=100000
